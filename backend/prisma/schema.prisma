generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum ClientType {
  PF
  PJ
}

enum ClientStatus {
  ACTIVE
  BLOCKED
  DEFAULTING
}

enum VehicleStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  SOLD
}

enum RentalStatus {
  OPEN
  CLOSED
  CANCELED
}

enum PaymentMethod {
  PIX
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum PhotoType {
  REGISTRATION
  PICKUP
  RETURN
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

model Company {
  id           String         @id @default(uuid())
  name         String
  document     String?        @unique
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  users        User[]
  clients      Client[]
  vehicles     Vehicle[]
  rentals      Rental[]
  contracts    Contract[]
  payments     Payment[]
  maintenances Maintenance[]
  washings     Washing[]
  notifications Notification[]
  auditLogs    AuditLog[]

  @@map("companies")
}

model User {
  id           String    @id @default(uuid())
  companyId    String    @map("company_id")
  company      Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  email        String
  passwordHash String    @map("password_hash")
  role         UserRole
  active       Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  washings     Washing[]
  auditLogs    AuditLog[]

  @@unique([companyId, email])
  @@index([companyId, role])
  @@map("users")
}

model Client {
  id            String           @id @default(uuid())
  companyId     String           @map("company_id")
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type          ClientType
  fullName      String           @map("full_name")
  cpfCnpj       String?          @map("cpf_cnpj")
  rgIe          String?          @map("rg_ie")
  birthDate     DateTime?        @map("birth_date")
  phone         String?
  email         String?
  status        ClientStatus     @default(ACTIVE)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  address       ClientAddress?
  documents     ClientDocument[]
  rentals       Rental[]
  notifications Notification[]

  @@index([companyId, status])
  @@index([companyId, fullName])
  @@map("clients")
}

model ClientAddress {
  id       String  @id @default(uuid())
  clientId String  @unique @map("client_id")
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  street   String
  number   String
  city     String
  state    String
  zipCode  String  @map("zip_code")

  @@map("client_addresses")
}

model ClientDocument {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       String
  fileUrl    String   @map("file_url")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@index([clientId, type])
  @@map("client_documents")
}

model Vehicle {
  id             String         @id @default(uuid())
  companyId      String         @map("company_id")
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  brand          String
  model          String
  year           Int
  color          String?
  plate          String
  chassis        String
  currentMileage Int            @default(0) @map("current_mileage")
  dailyRate      Decimal        @db.Decimal(10, 2) @map("daily_rate")
  weeklyRate     Decimal?       @db.Decimal(10, 2) @map("weekly_rate")
  monthlyRate    Decimal?       @db.Decimal(10, 2) @map("monthly_rate")
  status         VehicleStatus  @default(AVAILABLE)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  photos         VehiclePhoto[]
  rentals        Rental[]
  maintenances   Maintenance[]
  washings       Washing[]

  @@unique([companyId, plate])
  @@unique([companyId, chassis])
  @@index([companyId, status])
  @@map("vehicles")
}

model VehiclePhoto {
  id         String    @id @default(uuid())
  vehicleId  String    @map("vehicle_id")
  vehicle    Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  fileUrl    String    @map("file_url")
  type       PhotoType @default(REGISTRATION)
  uploadedAt DateTime  @default(now()) @map("uploaded_at")

  @@index([vehicleId, type])
  @@map("vehicle_photos")
}

model Rental {
  id                   String      @id @default(uuid())
  companyId            String      @map("company_id")
  company              Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId             String      @map("client_id")
  client               Client      @relation(fields: [clientId], references: [id])
  vehicleId            String      @map("vehicle_id")
  vehicle              Vehicle     @relation(fields: [vehicleId], references: [id])
  startDate            DateTime    @map("start_date")
  expectedReturnDate   DateTime    @map("expected_return_date")
  actualReturnDate     DateTime?   @map("actual_return_date")
  status               RentalStatus @default(OPEN)
  initialMileage       Int         @map("initial_mileage")
  currentMileage       Int?        @map("current_mileage")
  finalMileage         Int?        @map("final_mileage")
  pickupConditionNotes String?     @map("pickup_condition_notes")
  returnConditionNotes String?     @map("return_condition_notes")
  observations         String?
  estimatedTotal       Decimal     @db.Decimal(12, 2) @map("estimated_total")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  contract             Contract?
  payments             Payment[]
  notifications        Notification[]

  @@index([companyId, status])
  @@index([companyId, clientId])
  @@index([companyId, vehicleId])
  @@index([companyId, startDate])
  @@map("rentals")
}

model Contract {
  id                String    @id @default(uuid())
  companyId         String    @map("company_id")
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rentalId          String    @unique @map("rental_id")
  rental            Rental    @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  contractNumber    String    @map("contract_number")
  estimatedTotal    Decimal   @db.Decimal(12, 2) @map("estimated_total")
  pdfUrl            String?   @map("pdf_url")
  signatureProvider String?   @map("signature_provider")
  signedAt          DateTime? @map("signed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([companyId, contractNumber])
  @@index([companyId, createdAt])
  @@map("contracts")
}

model Payment {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  rentalId    String        @map("rental_id")
  rental      Rental        @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  dueDate     DateTime      @map("due_date")
  paidAt      DateTime?     @map("paid_at")
  amountDue   Decimal       @db.Decimal(12, 2) @map("amount_due")
  amountPaid  Decimal?      @db.Decimal(12, 2) @map("amount_paid")
  method      PaymentMethod @map("payment_method")
  status      PaymentStatus @default(PENDING)
  lateFee     Decimal?      @db.Decimal(10, 2) @map("late_fee")
  interest    Decimal?      @db.Decimal(10, 2)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([companyId, status, dueDate])
  @@index([companyId, rentalId])
  @@map("payments")
}

model Maintenance {
  id               String   @id @default(uuid())
  companyId        String   @map("company_id")
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleId        String   @map("vehicle_id")
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type             String
  description      String?
  maintenanceDate  DateTime @map("maintenance_date")
  cost             Decimal  @db.Decimal(12, 2)
  mileageAtService Int?     @map("mileage_at_service")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([companyId, vehicleId, maintenanceDate])
  @@map("maintenance")
}

model Washing {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicleId      String   @map("vehicle_id")
  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  employeeUserId String?  @map("employee_user_id")
  employee       User?    @relation(fields: [employeeUserId], references: [id], onDelete: SetNull)
  washingDate    DateTime @map("washing_date")
  cost           Decimal  @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([companyId, washingDate])
  @@index([companyId, vehicleId])
  @@map("washings")
}

model Notification {
  id               String              @id @default(uuid())
  companyId        String              @map("company_id")
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId         String              @map("client_id")
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rentalId         String?             @map("rental_id")
  rental           Rental?             @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  channel          NotificationChannel
  templateCode     String?             @map("template_code")
  message          String
  sentAt           DateTime?           @map("sent_at")
  deliveryStatus   String?             @map("delivery_status")
  providerResponse Json?               @map("provider_response")
  createdAt        DateTime            @default(now()) @map("created_at")

  @@index([companyId, sentAt])
  @@index([companyId, channel, deliveryStatus])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  entity    String
  entityId  String   @map("entity_id")
  action    String
  before    Json?    @map("before_json")
  after     Json?    @map("after_json")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([companyId, createdAt])
  @@index([companyId, entity, entityId])
  @@map("audit_logs")
}
